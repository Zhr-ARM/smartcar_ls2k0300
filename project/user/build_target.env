# build.sh 默认读取这个文件，切热点时优先改这里。
# 推荐只改 TARGET_PRESET，不要反复改脚本。
# 具体预设内容统一维护在 connection_presets.json。

CONNECTION_PRESETS_FILE="./connection_presets.json"

# 可选:
#   hotspot_a -> 172.21.79.138
#   hotspot_b -> 10.119.73.138
#   hotspot_c -> 172.21.79.138
#   hotspot_d -> 172.21.79.241
TARGET_PRESET="hotspot_a"

# 编译并行度
MAKE_JOBS="12"

# 摄像头采图分辨率开关（构建时生效）：
#   160 -> 160x120（处理阶段不走降采样）
#   320 -> 320x240（处理阶段会降采样到 160x120）
CAMERA_CAPTURE_WIDTH="160"

# NCNN 编译开关（构建时生效）：
#   0 -> 不链接 NCNN，保留红框可选链路，ncnn推理自动不可用
#   1 -> 启用 NCNN（若本地找不到库会自动降级为 0）
ENABLE_NCNN="0"
